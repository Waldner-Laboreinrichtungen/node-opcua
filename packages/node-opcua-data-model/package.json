  "description": "pure nodejs OPCUA SDK - module data-model",
  "scripts": {
    "build": "tsc -b",
    "test": "mocha",
    "test:check": "tsc --noEmit -p test/tsconfig.json",
    "lint": "eslint source test",
    "format": "prettier --write source test",
    "clean": "npx rimraf -g _generated_ dist *.tsbuildinfo",
    "coverage": "npx nyc node ../../node_modules/mocha/bin/mocha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "node-opcua-assert": "npm:@waldner-laboreinrichtungen/node-opcua-assert@2.169.0-ievent.1",
    "node-opcua-basic-types": "npm:@waldner-laboreinrichtungen/node-opcua-basic-types@2.169.0-ievent.1",
    "node-opcua-binary-stream": "npm:@waldner-laboreinrichtungen/node-opcua-binary-stream@2.169.0-ievent.1",
    "node-opcua-enum": "npm:@waldner-laboreinrichtungen/node-opcua-enum@2.169.0-ievent.1",
    "node-opcua-factory": "npm:@waldner-laboreinrichtungen/node-opcua-factory@2.169.0-ievent.1",
    "node-opcua-nodeid": "npm:@waldner-laboreinrichtungen/node-opcua-nodeid@2.169.0-ievent.1",
    "node-opcua-status-code": "npm:@waldner-laboreinrichtungen/node-opcua-status-code@2.169.0-ievent.1"
  },
  "devDependencies": {
    "node-opcua-packet-analyzer": "npm:@waldner-laboreinrichtungen/node-opcua-packet-analyzer@2.169.0-ievent.1"
