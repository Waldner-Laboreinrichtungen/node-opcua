    "opcua",
    "m2m",
    "iot",
    "opc ua",
    "internet of things"
  ],
  "homepage": "http://node-opcua.github.io/",
  "gitHead": "8ab3f6f99546f458799452f6dc5b838a37e645f2",
  "files": [
    "dist",
    "source"
