    "node-opcua-chunkmanager": "npm:@waldner-laboreinrichtungen/node-opcua-chunkmanager@2.169.0-ievent.1",
    "node-opcua-debug": "npm:@waldner-laboreinrichtungen/node-opcua-debug@2.169.0-ievent.1",
